# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://helpdesk_user:helpdesk_pass@localhost:5432/helpdesk_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Google Gemini (FREE at makersuite.google.com/app/apikey) ─────────────────
# Used as fallback when Ollama is not running
GEMINI_API_KEY=AIzaSy...your-key-here

# ── Ollama (LOCAL — install from ollama.com) ──────────────────────────────────
# Leave as-is if Ollama runs on the same machine (default port 11434)
OLLAMA_BASE_URL=http://localhost:11434

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
